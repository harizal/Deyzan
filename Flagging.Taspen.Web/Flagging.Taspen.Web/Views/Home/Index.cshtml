@{
    ViewData["Title"] = "Dashboard";
}

<!-- Main Content Row -->
<div class="row">
    <div class="col-md-5">
        <div class="card mb-4">
            <div class="card-header">
                <strong>
                    Checking Data
                </strong>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="searchInput" class="form-label">Masukan NIP / Notas</label>
                    <input type="text" class="form-control" id="searchInput" placeholder="Masukan NIP / Notas" onkeydown="if(event.key === 'Enter'){ event.preventDefault(); searchData(); }">
                </div>

                <button type="button" class="btn btn-primary" id="btnCari" onclick="searchData()" data-coreui-timeout="2000" data-coreui-toggle="loading-button">
                    <span id="btnText">Cari</span>
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <!-- Results Card -->
        <div class="card" id="resultCard" style="display: none">
            <div class="card-header">
                <strong>Hasil Pencarian</strong>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-5">
                        <label class="form-label">Nama Peserta / Penerima</label>
                        <input id="nama" type="text" class="form-control" disabled />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Tanggal Lahir Peserta / Penerima</label>
                        <input id="tanggalLahirPenerima" type="text" class="form-control" disabled />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-5">
                        <label class="form-label">Tanggal BUP / Wafat</label>
                        <input id="tanggalBUP" type="text" class="form-control" disabled />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Instansi / Kantor Bayar Pensiun</label>
                        <input id="instansi" type="text" class="form-control" disabled />
                    </div>
                </div>
                <div class="row">
                   <div class="col-md-10 p-2 mt-4">
                        <div class="alert alert-primary d-flex align-items-center" role="alert">
                            <svg class="icon-info">
                                <use xlink:href="../lib/coreui-icons/svg/free/cil-info.svg"></use>
                            </svg>
                            <div>
                              <span id="status"></span>
                            </div>
                        </div>
                        <div class="alert alert-warning d-flex align-items-center" role="alert">
                            <svg class="icon-info">
                                <use xlink:href="../lib/coreui-icons/svg/free/cil-info.svg"></use>
                            </svg>
                            <div>
                                <span id="statusFlaging"></span>
                            </div>
                        </div>
                   </div>
                </div>
                <input type="hidden" id="selectedPesertaId" />
            </div>
            <div class="card-footer text-body-secondary">
               <button type="button" class="btn btn-primary" id="btnBooking" onclick="booking()">
                    <span id="btnTextBooking">Booking</span>
                </button>
                <button type="button" class="btn btn-success ms-2" id="btnFlaging" onclick="flagging()">
                    <span id="btnTextFlaging">Flaging Pensiun</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Search Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true" data-coreui-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalLabel">Konfirmasi</h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Apakah yakin akan mencari data?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Tidak</button>
                <button type="button" class="btn btn-primary" id="btnConfirmYes">Ya</button>
            </div>
        </div>
    </div>
</div>

<!-- Booking Confirmation Modal -->
<div class="modal fade" id="bookingModal" tabindex="-1" aria-labelledby="bookingModalLabel" aria-hidden="true" data-coreui-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="bookingModalLabel">Booking</h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Anda akan melakukan Booking ? Jangka waktu booking selama 1x24 jam.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">No</button>
                <button type="button" class="btn btn-primary" id="btnBookingYes">Yes</button>
            </div>
        </div>
    </div>
</div>

<!-- Flaging Pensiun Confirmation Modal -->
<div class="modal fade" id="flaggingModal" tabindex="-1" aria-labelledby="flaggingModalLabel" aria-hidden="true" data-coreui-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="flaggingModalLabel">Flaging Pensiun</h5>
                <button type="button" class="btn-close" data-coreui-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Anda akan melakukan Flaging Pensiun ? Proses Flaging Pensiun akan dikenakan biaya sebesar Rp40.000,00 rupiah.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">No</button>
                <button type="button" class="btn btn-primary" id="btnFlaggingYes">Yes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const confirmModal = new coreui.Modal(document.getElementById('confirmModal'));
        const bookingModal = new coreui.Modal(document.getElementById('bookingModal'));

        const flaggingModal = new coreui.Modal(document.getElementById('flaggingModal'));

        let searchInput = null;
        const selectedPesertaId = document.getElementById('selectedPesertaId');

        function initSearchInput() {
            searchInput = document.getElementById('searchInput');
            if (!searchInput) return;

            searchInput.addEventListener('keydown', function(event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    searchData();
                }
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initSearchInput);
        } else {
            initSearchInput();
        }

        // Click "Cari" -> show modal
        function searchData() {
            const input = searchInput.value.trim();
            if (!input) {
                ShowAlert('warning', 'Input Kosong', 'Masukkan NIP atau Notas terlebih dahulu');
                return;
            }
            confirmModal.show();
        }

        // Click "Ya" on search modal -> execute search
        document.getElementById('btnConfirmYes').addEventListener('click', function() {
            confirmModal.hide();
            performSearch();
        });

        document.getElementById('btnBookingYes').addEventListener('click', function() {
            bookingModal.hide();
            performBooking();
        });

        async function performSearch() {
            const input = searchInput.value.trim();
            LoadingButton(true, 'btnCari', 'Cari');

            const resultCard = document.getElementById('resultCard');
            resultCard.style.display = 'none';

            try {
                const response = await fetch(`@Url.Action("SearchData", "Home")?query=${encodeURIComponent(input)}`);
                const data = await response.json();

                if (data.isSuccess) {
                    $("#nama").val(data.data.nama);
                    $("#tanggalLahirPenerima").val(data.data.tanggalLahir);
                    $("#tanggalBUP").val(data.data.tanggalBUP);
                    $("#instansi").val(data.data.instansi);
                    $("#status").text(data.data.status);
                    $("#statusFlaging").text(data.data.status);
                    selectedPesertaId.value = data.data.statusFlaging;
                    updateBookingButton(data.data.isBooking);
                    updateFlagingButton(data.data.isFlaging);

                    resultCard.style.display = 'block';
                } else {
                    ShowAlert('warning', 'Data Tidak Ditemukan', 'NIP atau Notas yang Anda cari tidak ditemukan');
                }
            } catch (error) {
                ShowAlert('danger', 'Error', 'Terjadi kesalahan saat mencari data');
            } finally {
                LoadingButton(false, 'btnCari', 'Cari');
            }
        }

        function updateBookingButton(isBooking) {
            const bookingButton = document.getElementById('btnBooking');
            if (!bookingButton) return;

            bookingButton.disabled = isBooking;
            if (isBooking) {
                bookingButton.classList.remove('btn-primary');
                bookingButton.classList.add('btn-secondary');
                bookingButton.innerText = 'Sudah Booking';
            } else {
                bookingButton.classList.remove('btn-secondary');
                bookingButton.classList.add('btn-primary');
                bookingButton.innerText = 'Booking';
            }
        }

        function updateFlagingButton(isFlaging) {
            const flagingButton = document.getElementById('btnFlaging');
            if (!flagingButton) return;

            flagingButton.disabled = isFlaging;
            if (isFlaging) {
                flagingButton.classList.remove('btn-primary');
                flagingButton.classList.add('btn-secondary');
                flagingButton.innerText = 'Sudah Booking';
            } else {
                flagingButton.classList.remove('btn-secondary');
                flagingButton.classList.add('btn-primary');
                flagingButton.innerText = 'Booking';
            }
        }

        function booking() {
            const bookingButton = document.getElementById('btnBooking');
            if (bookingButton?.disabled) {
                return;
            }

            if (!selectedPesertaId.value) {
                ShowAlert('warning', 'Data belum dipilih', 'Cari peserta terlebih dahulu sebelum melakukan Booking');
                return;
            }
            bookingModal.show();
        }

        async function performBooking() {
            LoadingButton(true, 'btnBooking', 'Booking');
            try {
                const response = await fetch(`@Url.Action("Booking", "Home")?id=${encodeURIComponent(selectedPesertaId.value)}`, {
                    method: 'POST'
                });
                const data = await response.json();

                if (data.isSuccess) {
                    ShowAlert('success', 'Booking Berhasil', data.message || 'Booking berhasil disimpan');
                    await performSearch();
                } else {
                    ShowAlert('warning', 'Booking Gagal', data.message || 'Gagal menyimpan booking');
                    LoadingButton(false, 'btnBooking', 'Booking');
                }
            } catch (error) {
                ShowAlert('danger', 'Error', 'Terjadi kesalahan saat memproses booking');
                LoadingButton(false, 'btnBooking', 'Booking');
            }
        }

        async function flagging() {
            flaggingModal.show();
        }

        async function performFlaging(){
            LoadingButton(true, 'btnFlaging', 'Flaging Pensiun');
            try{
                 const response = await fetch(`@Url.Action("FlagingFlag", "Home")?id=${encodeURIComponent(selectedPesertaId.value)}`, {
                    method: 'POST'
                });
                const data = await response.json();

                if (data.isSuccess) {
                     ShowAlert("success", "Success!", "Redirecting to Flaging Page...");
                        setTimeout(function () {
                            window.location = '@Url.Action("Flaging", "Home")?idPeserta=' + encodeURIComponent(selectedPesertaId.value);
                        }, 1500);
                } else {
                    ShowAlert('warning', 'Flaging Gagal', data.message || 'Gagal menyimpan Flaging');
                    LoadingButton(false, 'btnFlaging', 'Flaging Pensiun');
                }
            }catch{
                ShowAlert('danger', 'Error', 'Terjadi kesalahan saat memproses booking');
                LoadingButton(false, 'btnFlaging', 'Flaging Pensiun');
            }
        }

        document.getElementById('btnFlaggingYes').addEventListener('click', function() {
             flaggingModal.show();
             window.location = '@Url.Action("Flaging", "Home")?idPeserta=' + encodeURIComponent(selectedPesertaId.value);
        });
    </script>
}
