@{
    ViewData["Title"] = "Data Peserta";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.5/css/jquery.dataTables.min.css" />

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Data Peserta</strong>
        <a class="btn btn-primary" href="@Url.Action("Create", "Peserta")">Tambah Peserta</a>
    </div>
    <div class="card-body">
        <table id="pesertaTable" class="table table-striped table-bordered" style="width:100%">
            <thead>
                <tr>
                    <th>No</th>
                    <th>NIP</th>
                    <th>Notas</th>
                    <th>No KPE</th>
                    <th>Nama</th>
                    <th>Tanggal Lahir</th>
                    <th>Instansi</th>
                    <th>NIK</th>
                    <th>No Telpon</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.5/js/jquery.dataTables.min.js"></script>
    <script>
        $(function () {
            $('#pesertaTable').DataTable({
                dom: 'lrtip',
                ajax: {
                    url: '@Url.Action("GetPesertaData", "Peserta")',
                    dataSrc: 'data'
                },
                columns: [
                    {
                        data: null,
                        title: 'No',
                        render: function (data, type, row, meta) {
                            return meta.row + 1;
                        },
                        orderable: false,
                        searchable: false
                    },
                    { data: 'nip', title: 'NIP' },
                    { data: 'notas', title: 'Notas' },
                    { data: 'noKPE', title: 'No KPE' },
                    { data: 'nama', title: 'Nama' },
                    { data: 'tanggalLahir', title: 'Tanggal Lahir' },
                    { data: 'instansi', title: 'Instansi' },
                    { data: 'nik', title: 'NIK' },
                    { data: 'noTel', title: 'No Telpon' },
                    {
                        data: 'id',
                        title: 'Aksi',
                        orderable: false,
                        searchable: false,
                        render: function (data, type, row, meta) {
                            return '<a class="btn btn-sm btn-warning" href="/Peserta/Edit/' + data + '">Edit</a>';
                        }
                    }
                ],
                pageLength: 10,
                responsive: true
            });
        });
    </script>
}
